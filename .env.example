# Copy to .env for local development (optional).

# Plasmod gateway — match your deployment:
#   docker compose up -d (split):     http://127.0.0.1:19530  (default below)
#   docker-compose.unified.yml / go run: http://127.0.0.1:8080
PLASMOD_BASE_URL=http://127.0.0.1:19530
PLASMOD_HTTP_TIMEOUT=30

# Admin API key (for /v1/admin/* on mgmt port 9091 in split mode, or unified :8080)
PLASMOD_ADMIN_API_KEY=

# Legacy aliases
# ANDB_BASE_URL=http://127.0.0.1:19530
# ANDB_HTTP_TIMEOUT=30
# ANDB_ADMIN_API_KEY=
