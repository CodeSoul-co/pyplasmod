# Please copy this file and rename as .env, pyplasmod will read .env file if provided

# Plasmod server configuration
PLASMOD_BASE_URL=http://127.0.0.1:8080
PLASMOD_HTTP_TIMEOUT=30

# Admin API key (for /v1/admin/* routes)
PLASMOD_ADMIN_API_KEY=

